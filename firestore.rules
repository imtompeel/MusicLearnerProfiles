rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Student join sessions — open for classroom QR join flow
    match /sessions/{sessionCode} {
      allow read, write: if true;
    }

    // Teacher class data — signed-in teachers only
    match /classes/{classId} {
      allow read, write: if request.auth != null;
    }

    // Instrument library — signed-in teachers only
    match /instrument_library_instruments/{instrumentId} {
      allow read, write: if request.auth != null;
    }
    match /instrument_library_loans/{loanId} {
      allow read, write: if request.auth != null;
    }

    // Documentary planning — owner only
    match /documentary_planning/{planId} {
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;
      allow read, update, delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
    }

    // Auto scroll saved texts — owner only
    match /auto_scroll_texts/{textId} {
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;
      allow read, update, delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

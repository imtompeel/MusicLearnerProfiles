rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isControllerGif() {
      return request.resource.contentType == 'image/gif';
    }

    function withinControllerSizeLimit() {
      return isControllerGif()
        ? request.resource.size < 50 * 1024 * 1024
        : request.resource.size < 5 * 1024 * 1024;
    }

    match /controller_images/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && withinControllerSizeLimit()
        && request.resource.contentType.matches('image/.*');

      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /colour_tracker_sounds/{userId}/{quadrantId}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('audio/.*');

      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}

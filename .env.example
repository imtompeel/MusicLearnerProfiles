# Firebase Configuration
# Copy this file to .env (with the leading dot) and fill in your values.
# Vite does NOT load a file named "env" — it must be ".env".

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=your-app-id
VITE_FREESOUND_API_KEY=YOUR_FREESOUND_API_KEY
VITE_UNSPLASH_ACCESS_KEY=YOUR_UNSPLASH_ACCESS_KEY
# Set to true if Unsplash is blocked on your network (uses placeholder images instead)
VITE_SKIP_UNSPLASH_API=false